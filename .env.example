# Copy to .env and fill in. .env is gitignored — never commit real values.
# Note: the Python SDK does NOT read env vars; our code reads these and passes
# them to Config(base_url, ws_url) and AgentClient(config, sdk_key=...).
# Key var named CROO_API_KEY to match the Agent Store dashboard quickstart.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
# Proov (Provider) agent key
CROO_API_KEY=croo_sk_...
# Requester (test buyer) agent key — used in Story 1.3+ to place test orders against Proov
CROO_REQUESTER_API_KEY=croo_sk_...
# Companion "Research" agent key (Story 4.2) — a DISTINCT registered agent that hires Proov as
# its acceptance step (scripts/research_caller.py), so the A2A composition order is a trade
# between two distinct agents and self-trade accounting stays legible (set its agent id in
# PROOV_OWN_AGENT_IDS below). Optional: if unset, the caller falls back to CROO_REQUESTER_API_KEY.
# The live order spends real USDC on Base (funding-gated, like the requester) — run it sparingly.
CROO_COMPANION_API_KEY=croo_sk_...

# --- LLM (Story 2.1, claim extraction) — all optional; the test suite runs offline ---
# Required only for the LIVE Gemini provider (free key from Google AI Studio).
# GOOGLE_API_KEY is also accepted as a fallback. Sent via the x-goog-api-key header, never a URL.
GEMINI_API_KEY=
# Provider selection: `gemini` (default) or `stub` (deterministic, offline, $0).
PROOV_LLM_PROVIDER=gemini
PROOV_LLM_MODEL=gemini-2.5-flash
# Per-call timeout in seconds (garbage falls back to 30).
PROOV_LLM_TIMEOUT=30

# --- Search (Story 2.2, evidence retrieval) — all optional; the test suite runs offline ---
# Tavily is the optional RAG-native primary source (free key from tavily.com). WITHOUT it,
# retrieval is Wikipedia-only (keyless, always available). Sent via the
# `Authorization: Bearer` header, never a URL/body.
TAVILY_API_KEY=
# Force a single provider: `wikipedia` | `tavily` | `stub`. Unset = auto chain
# (Tavily→Wikipedia when TAVILY_API_KEY is set, else Wikipedia only).
PROOV_SEARCH_PROVIDER=
# Per-call (per-claim) timeout in seconds (garbage falls back to 10).
PROOV_SEARCH_TIMEOUT=10

# --- Citation check (Story 2.4) — optional; the test suite runs offline ---
# Per-source citation fetch timeout in seconds (garbage falls back to 10). Support reuses
# the LLM env above (no new LLM var); this bounds only the per-URL retrievability GET.
PROOV_CITATION_TIMEOUT=10
# Browser-like User-Agent for the citation retrievability GET (Story 3.1). A blank value falls
# back to a built-in desktop Chrome UA, which helps avoid bot-blocking 403s; only a definitive
# 404/410 is treated as `fabricated`, so a blocked source is `ok`, never a false alarm.
PROOV_CITATION_USER_AGENT=

# --- Quick Check end-to-end (Story 2.6) — optional ---
# Per-ORDER SLA budget in seconds for a Quick verification (the whole single-pass pipeline).
# Default 240 (4 min — under the 5-min Quick SLA, leaving headroom for canonicalise +
# deliver + async settlement). When the budget is exceeded mid-run the engine stops early
# and aggregates whatever was judged into an honest `partial` (degrade, don't drop), rather
# than letting the order fall to an SLA timeout. Garbage / non-finite / ≤0 falls back to 240.
PROOV_QUICK_SLA_SECONDS=240

# --- Deep Verify (Story 2.7) — optional; the test suite runs offline ---
# Deep runs the SAME pipeline as Quick, but its slices do more: multi-source evidence merge,
# multi-pass (self-consistency) judgment, provided+discovered citations, a wider SLA budget,
# and a downloadable full report for large deliverables.
# Per-ORDER SLA budget in seconds for a Deep verification. Default 1680 (28 min — under the
# 30-min Deep SLA, leaving ~2 min for canonicalise + upload_file + deliver + async
# settlement). Same early-stop → `partial` behaviour as Quick. Garbage / non-finite / ≤0
# falls back to 1680.
PROOV_DEEP_SLA_SECONDS=1680
# Self-consistency passes per claim — the Deep judge samples the provider this many times and
# reduces to one consensus (majority status; tie → unverifiable; agreement-weighted
# confidence). Default 3; non-int / ≤0 falls back to 3; capped at 7 to bound cost/SLA.
PROOV_DEEP_JUDGE_PASSES=3
# Byte size at/above which a Deep deliverable is ALSO uploaded via upload_file and linked by a
# `report_file` sibling (a downloadable full copy; the inline schema+receipt is unchanged).
# Default 51200 (50 KB); non-int / ≤0 falls back to 51200. Best-effort: an upload failure
# degrades to inline delivery without the link (never drops the order).
PROOV_DEEP_UPLOAD_THRESHOLD_BYTES=51200

# --- Claim→evidence cache (Story 2.8) — optional; the test suite runs with caching disabled ---
# A TTL'd SQLite cache of claim→retrieved-evidence, keyed on (normalised claim, tier, k). A
# repeated claim is served from cache with no new search-provider call (cost/latency at volume,
# FR11). Best-effort: every cache failure degrades to a miss/no-op — it never fails an order or
# changes a verdict. No new dependency (sqlite3 is stdlib).
# Cache on by default; 0/false/no/off (case-insensitive) disables it.
PROOV_CACHE_ENABLED=1
# SQLite file path (repo-root-relative, gitignored via *.db). `:memory:` also works.
PROOV_CACHE_PATH=proov_cache.db
# Entry lifetime in seconds (default 86400 = 24 h). Garbage / non-finite / ≤0 falls back to 86400.
PROOV_CACHE_TTL_SECONDS=86400

# --- Metrics + dashboard (Story 3.2) — optional; the test suite runs with the ledger disabled ---
# A best-effort SQLite order/metrics ledger the provider writes at every terminal order (tier +
# cost + a snapshot of counterparty/wallet/price/status), reconciled with real `list_orders` by
# `scripts/dashboard.py` for the success/counter-metric dashboard. Best-effort: every ledger
# failure degrades to a no-op — it never fails or slows a paid order. No new dependency.
# Ledger on by default; 0/false/no/off (case-insensitive) disables it.
PROOV_LEDGER_ENABLED=1
# SQLite file path for the ledger (repo-root-relative, gitignored via *.db). `:memory:` works too.
PROOV_LEDGER_PATH=proov_ledger.db
# Comma-separated self/companion agent ids that count as a SELF-TRADE order (the counter-metric:
# external orders must dominate). Story 4.2 mints the companion Research caller's agent
# (CROO_COMPANION_API_KEY above) — set this to that agent's id so the dashboard attributes its
# orders to self-trade and EXCLUDES them from the external-buyer count. (If the caller falls back
# to the requester key instead, put the requester's agent id here.) Default empty.
PROOV_OWN_AGENT_IDS=
# Documented per-order marginal cost shown as cost/order. Default 0.0 = the free-tier stack
# (Gemini/Tavily/Wikipedia free quotas → $0 marginal, NFR1); override when a tier moves to paid
# quota. Non-numeric falls back to 0.0. Real measured cost + a ceiling is Story 3.4.
PROOV_QUICK_COST_USD=0.0
PROOV_DEEP_COST_USD=0.0

# --- Reliability hardening (Story 3.3) — all optional; sane defaults; offline-safe ---
# Worker-pool size: at most this many orders run their LLM/search-heavy verification at once (the
# rest queue), keeping concurrent verifications under the free-tier RPM (Gemini ~10 RPM / Tavily).
# Garbage / non-int / ≤0 falls back to 3.
PROOV_MAX_CONCURRENT_ORDERS=3
# Graceful-shutdown drain budget (seconds): an in-flight deliver_order/reject_order (a live on-chain
# settlement) is awaited up to this long before the socket closes; stragglers are then cancelled.
# Garbage / non-finite / ≤0 falls back to 25.
PROOV_SHUTDOWN_DRAIN_SECONDS=25
# Bounded idempotency: the most-recent N handled negotiation/order ids are kept (older evicted FIFO)
# so memory stays bounded under sustained load. Garbage / non-int / ≤0 falls back to 4096.
PROOV_IDEMPOTENCY_MAX=4096
# Evidence-cache size-cap: a row count above this prunes the oldest rows on put (the lazy TTL-on-read
# prune never evicts a write-once-never-read key). ≤0 disables the cap; garbage falls back to 10000.
PROOV_CACHE_MAX_ROWS=10000

# --- Cost guardrails (Story 3.4) — all optional; the defaults keep the stack $0/offline ---
# Per-order cost ceiling (USD). The engine accumulates each judged claim's estimated marginal cost
# and stops early → an honest `partial` before the order would breach this (also skips the paid
# citation check). Default 0.0 DISABLES the meter entirely — the $0 free-tier path is unchanged.
# Garbage / non-finite / negative falls back to 0.0.
PROOV_MAX_ORDER_COST_USD=0.0
# Documented per-CLAIM marginal cost the ceiling meters against (the per-order twin is
# PROOV_QUICK_COST_USD / PROOV_DEEP_COST_USD above). Default 0.0 = free-tier stack; override when a
# tier carries a real per-call price. Non-numeric / non-finite falls back to 0.0.
PROOV_QUICK_CLAIM_COST_USD=0.0
PROOV_DEEP_CLAIM_COST_USD=0.0
# Cap on the number of buyer-PROVIDED citation sources fetched+judged per order — bounds paid-call
# amplification from a giant `sources` array. Default 50 (generous); non-int / ≤0 falls back to 50.
# Deep discovered sources are zero-cost and unaffected.
PROOV_MAX_SOURCES=50

# --- Human "Try this" demo page (Story 4.1) — optional; stdlib http.server, no new dep ---
# The free, off-protocol verification page (`python scripts/try_this.py`) — same engine path as a
# paid order, but no CAP order / payment / on-chain anchor. Bind address + port for that runner;
# its own process, separate from the provider's WebSocket loop (`python -m proov`). Garbage / ≤0
# falls back to the default. With no API keys it runs $0 offline (stub + Wikipedia, optimistic) —
# set GEMINI_API_KEY (above) for a meaningful demo. Public exposure spends free-tier quota, so
# keep the default 127.0.0.1 bind unless you intend a public demo.
PROOV_TRYTHIS_HOST=127.0.0.1
PROOV_TRYTHIS_PORT=8080
