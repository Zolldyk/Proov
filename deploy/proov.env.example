# Proov host secrets/config — systemd EnvironmentFile template.
#
# INSTALL:
#   sudo install -d -m 700 /etc/proov
#   sudo cp deploy/proov.env.example /etc/proov/proov.env
#   sudo chown root:root /etc/proov/proov.env
#   sudo chmod 600 /etc/proov/proov.env
#   sudo editor /etc/proov/proov.env        # fill in real values
#
# NEVER commit a filled-in copy. This `.example` is the only tracked file; the real
# /etc/proov/proov.env lives OFF the repo tree on the host (and .gitignore excludes .env*).
#
# FORMAT: systemd EnvironmentFile is literal `KEY=value` — NO `export`, NO surrounding
# quotes (quotes become part of the value). One var per line; `#` comments allowed.
#
# For the full meaning of every optional knob below, see the repo's `.env.example` — this
# file lists only what the always-on host typically needs and does not duplicate that prose.

# --- Required (the provider fails fast naming the first missing one) ---
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws
CROO_API_KEY=croo_sk_REPLACE_ME

# --- Common operational knobs (optional; sane defaults if omitted) ---
LOG_LEVEL=INFO
# Graceful-shutdown drain budget. Keep TimeoutStopSec in proov.service GREATER than this.
PROOV_SHUTDOWN_DRAIN_SECONDS=25

# --- Optional provider keys — set only the tiers you run with (else $0 offline stack) ---
# Live LLM (Gemini free key); GOOGLE_API_KEY also accepted as a fallback.
GEMINI_API_KEY=
# Optional RAG-native search (Tavily free key); without it, retrieval is Wikipedia-only.
TAVILY_API_KEY=

# Companion/requester keys are only needed if you ALSO run the buyer-side scripts on this
# host (scripts/research_caller.py / scripts/place_test_order.py). The provider itself does
# not need them. Each must be a DISTINCT registered agent (one key, one process — see below).
# CROO_REQUESTER_API_KEY=
# CROO_COMPANION_API_KEY=
